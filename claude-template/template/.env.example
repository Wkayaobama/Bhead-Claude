# The only secret the app needs. The Anthropic SDK reads this directly
# from the environment — see backend/app/llm.py get_client().
ANTHROPIC_API_KEY=sk-ant-...

# Default model for backend/app/llm.py helpers (not a secret).
AI_MODEL=claude-opus-4-8

# Optional port overrides
# BACKEND_PORT=8000
# FRONTEND_PORT=5173
