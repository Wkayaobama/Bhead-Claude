# The only secret the app needs. The Anthropic SDK reads this directly
# from the environment — see backend/app/llm.py get_client().
ANTHROPIC_API_KEY=sk-ant-...

# Default model for backend/app/llm.py helpers (not a secret).
AI_MODEL=claude-opus-4-8

# Headless workflows: host directory mounted at /repo inside the
# backend container — the working directory for `claude -p` runs
# (/review, /security-review, ...). Defaults to this project itself.
# WORKFLOW_TARGET_DIR=../some-other-repo

# Optional port overrides
# BACKEND_PORT=8000
# FRONTEND_PORT=5173
