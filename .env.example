PROJECT_ID=myapp
MONGO_DB=myapp

# Injected by the App Builder orchestrator at project-creation time.
# Do not paste a key by hand — the orchestrator mints one from UT-API
# using the connected user's Firebase credentials.
UT_API_KEY=
# Understand Tech backend API host. The orchestrator passes the right
# value through at project-creation time (staging API ALB in dev,
# `developer.understand.tech` in prod). `ut_usage.increment_prompt`
# POSTs to `${UNDERSTAND_API_URL}/api/user/usage/increment-private`.
UNDERSTAND_API_URL=https://developer.understand.tech
# UT LLM gateway URL. `claude_examples.get_client()` configures the
# Anthropic SDK to talk to this endpoint using UT_API_KEY as the
# bearer. The app never holds a raw provider key.
# Only set in standard mode (LLM_MODE=standard). In air-gap mode
# (LLM_MODE=airgap) this is intentionally NOT set — chat goes through
# UT API v3 directly (`ut_ai_examples.py`), and the orchestrator's
# Anthropic proxy will refuse calls from air-gap projects.
UT_LLM_BASE_URL=http://host.docker.internal:8001/api/llm/anthropic
# LLM mode this app was generated for. Set by the orchestrator at
# project-creation time; do not edit by hand.
#   standard  — chat via Anthropic SDK + orchestrator's LLM proxy
#               (use `app/claude_examples.py`)
#   airgap    — chat via UT API v3, model "Understand AI"
#               (use `app/ut_ai_examples.py`); requires Enterprise plan
LLM_MODE=standard
# Default model for chat calls. In standard mode this is a Claude
# variant; in airgap mode it is "Understand AI". Read by both
# `claude_examples.py` (legacy: `settings.ai_model`) and
# `ut_ai_examples.get_model()`.
AI_MODEL=claude-sonnet-4-6
